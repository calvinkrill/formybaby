rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // global helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    
    // Visit Validation
    function isValidVisit(data) {
      return data.keys().hasAll(['timestamp', 'userAgent']) 
        && data.keys().size() == 2
        && data.timestamp is timestamp
        // Verify it's roughly current time (server timestamp)
        && data.timestamp == request.time
        && data.userAgent is string
        && data.userAgent.size() <= 1000;
    }

    match /visits/{visitId} {
      allow create: if isValidId(visitId) && isValidVisit(incoming());
      // No updates or deletions allowed
      allow update, delete: if false;
      // Anyone can read visits to count them
      allow get, list: if true;
    }
  }
}
